# Jellyfin Enhanced — repo conventions, codified (v12 Phase 4 analyzer ratchet).
#
# Rules mirror the style the codebase already uses; nothing here reformats
# existing code. Build-breaking strictness lives in the csproj
# (TreatWarningsAsErrors + EnforceCodeStyleInBuild): only diagnostics
# explicitly promoted to warning/error below can fail the build — ratchet
# them up one at a time, with the fix, in the same commit.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ── C# ────────────────────────────────────────────────────────────────────
[*.cs]
indent_style = space
indent_size = 4

# Match current usage: both block-scoped (plugin) and file-scoped (tests)
# namespaces exist — do not enforce either.
csharp_style_namespace_declarations = block_scoped:silent

# var usage follows the file's local style today; keep as suggestions only.
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:silent

# Prefer language keywords (string, int) over BCL names — already universal.
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# No this. qualification — already universal (fields are _camelCase).
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Private fields are _camelCase; constants/statics follow member casing.
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.capitalization = camel_case
dotnet_naming_style.underscore_camel.required_prefix = _

# Modifier hygiene — cheap, already clean.
dotnet_diagnostic.IDE0044.severity = suggestion  # make field readonly
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion

# ── MSBuild / config files ────────────────────────────────────────────────
[*.{csproj,slnx,props,targets}]
indent_style = space
indent_size = 2

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

# ── Web assets (eslint owns lint; this pins whitespace only) ──────────────
[*.{js,ts,css,html}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
