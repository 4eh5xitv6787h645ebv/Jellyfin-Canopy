<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Unit tests for the plugin. The test project always runs against the default
    (jf12 / net10.0) build of the plugin; the jf10 (net9.0) target is compiled
    separately in CI for compile-safety. Logic under test here is runtime-agnostic.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RootNamespace>Jellyfin.Plugin.JellyfinEnhanced.Tests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Jellyfin.Plugin.JellyfinEnhanced\JellyfinEnhanced.csproj" />
  </ItemGroup>

</Project>
